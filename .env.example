# Port d'écoute de l'application (défaut : 5050)
PORT=5050

# Clé secrète Flask — générée automatiquement au premier démarrage si absente
# Vous pouvez aussi la définir manuellement ici
# SECRET_KEY=changez-cette-valeur

# Mode debug Flask (ne pas activer en production)
# FLASK_DEBUG=false

# Archivage automatique : nb de jours après lesquels les candidatures
# en Refus ou Désistement sont archivées automatiquement (défaut : 30)
# AUTO_ARCHIVE_DAYS=30
