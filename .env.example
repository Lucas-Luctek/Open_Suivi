# Copier ce fichier en .env et adapter les valeurs

# Clé secrète Flask — OBLIGATOIRE (générée automatiquement par setup.sh)
SECRET_KEY=changez-cette-cle-en-production-svp

# Nom de l'application affiché dans l'interface (modifiable aussi via Admin > Personnalisation)
COMPANY_NAME=Postulo

# Port d'écoute
PORT=5050

# Mode debug Flask (ne jamais mettre true en production)
FLASK_DEBUG=false
